# ============================================================
# BookAutomation Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# ============================================================

# Django Core
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database: Neon PostgreSQL ----
# Format: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/bookautomation?sslmode=require

# ---- Redis: Upstash (use rediss:// for TLS) ----
# Format: rediss://default:<token>@<endpoint>.upstash.io:6379
REDIS_URL=rediss://default:your-token@your-endpoint.upstash.io:6379

# Celery broker (same as Redis URL)
CELERY_BROKER_URL=rediss://default:your-token@your-endpoint.upstash.io:6379

# ---- Google Gemini AI ----
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemma-3-27b-it
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ---- ChromaDB (local persistent storage) ----
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=book_chunks

# ---- AI Cache TTL ----
# AI response cache lifetime in seconds (default: 86400 = 24 hours)
AI_CACHE_TTL=86400
